<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>About | LabReserve</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <style>
    body {
      background: #087830;
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
      padding: 20px;
    }

    .about-card {
      background: #fff;
      padding: 60px 40px 70px 40px;
      border-radius: 15px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
      max-width: 700px;
      width: 100%;
      min-height: 550px;
      text-align: center;
    }

    .about-card h2 {
      color: #087830;
      margin-bottom: 15px;
    }

    .about-card p.subtitle {
      color: #555;
      margin-bottom: 25px;
      font-size: 1.1em;
    }

    .about-card p.description {
      color: #333;
      line-height: 1.6;
      margin-bottom: 30px;
    }

    .about-card ul.description {
      text-align: left;
      margin: 0 auto 30px auto;
      padding-left: 20px;
      max-width: 400px;
      color: #333;
      line-height: 1.6;
    }

    .btn-home {
      background: #087830;
      color: #fff;
      padding: 12px 25px;
      border: none;
      border-radius: 8px;
      font-size: 1em;
      cursor: pointer;
      transition: background 0.3s;
      text-decoration: none;
    }

    .btn-home:hover {
      background: #065f24;
    }
  </style>
</head>

<body>

  <div class="about-card">
    <h2></strong>About LabReserve.</strong></h2>
    <h3 class="subtitle">LabReserve is built with NodeJS, Express, MongoDB, & Handlebars.</h3>
    <p class="description"><strong>NPM Packages/Dependencies:</strong></p>
    <ul class="description">
      <li>bcryptjs</li>
      <li>connect-mongo</li>
      <li>dotenv</li>
      <li>express</li>
      <li>express-fileupload</li>
      <li>express-handlebars</li>
      <li>express-session</li>
      <li>mongoose</li>
      <li>socket.io</li>
    </ul>
    <a href="/home" class="btn-home">Go back to Homepage</a>
  </div>

</body>

</html>
