<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Home Page</title>
    <link rel="stylesheet" href="../css/styles.css" />
  </head>

  <body class="bg">
    <div class="portal">
      <h1 class="welcome-title">Welcome to LabReserve.</h1>
      <br /><br />
      <p class="italics">Select a feature to continue</p>

      <div class="portal-grid">
        <!-- admin-only feature -->
        {{#if (eq user.role "Lab Technician")}}
          <a href="/adminSearch" class="portal-card"> 
            <h2>Search</h2>
            <p>Search and view students' reservations.</p>
          </a>
        {{/if}}

        <a href="/labs" class="portal-card">
          <h2>Laboratories</h2>
          <p>View available laboratory seats.</p>
        </a>

        <a href="/reservation" class="portal-card">
          <h2>Reserve</h2>
          <p>Book a laboratory seat reservation.</p>
        </a>

        <a href="/manage" class="portal-card">
          <h2>Manage</h2>
          <p>Manage your current seat reservation/s.</p>
        </a>

        <a href="/profile/{{user._id}}" class="portal-card">
          <h2>Profile</h2>
          <p>Manage your profile information.</p>
        </a>

        <a href="#" id="logoutBtn" class="portal-card">
          <h2>Logout</h2>
          <p>Logout of your current account.</p>
        </a>
      </div>
    </div>

    <script src="/js/script.js"></script>
  </body>
</html>