<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Student Lookup</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>

  <body class="bg">
    <header>
      <nav class="navbar">
        <a class="logo" href="/home">LabReserve.</a>
        <ul class="nav-links">
          {{#if (eq user.role "Lab Technician")}}
            <li><a href="/adminSearch">Search</a></li>
          {{/if}}
          <li><a href="/labs">Laboratories</a></li>
          <li><a href="/reservation">Reserve</a></li>
          <li><a href="/manage">Manage</a></li>
          <li><a href="/profile/{{user._id}}">Profile</a></li>
          <li><a href="#" id="logoutBtn">Logout</a></li>
        </ul>
      </nav>
    </header>

    <main class="container">
      <h2>Student Reservation Lookup</h2>
      <p class="subtitle">Enter student email to view/manage their reservations.</p>
      
      <div class="form-card" style="max-width: 450px;">
        <form method="POST" action="/adminSearch">
          <div class="form-group">
            <label>Student Email</label>
            <input type="email" name="email" id="searchInput" 
                   placeholder="student@dlsu.edu.ph" required 
                   style="font-size: 16px;" />
          </div>
          <button type="submit" class="btn-large">View Reservations</button>
        </form>
      </div>

      {{#if error}}
        <div class="form-card" style="background: #fee; color: #c33; border-left: 4px solid #f66;">
          <p><strong>{{error}}</strong></p>
          <p style="font-size: 14px;">Make sure the email exists and belongs to a Student account.</p>
        </div>
      {{/if}}
    </main>

    {{> logout}}
    <script src="/js/script.js"></script>
  </body>
</html>
