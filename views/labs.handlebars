<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Our Laboratories</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>

<body class="bg">

  <header>
    <nav class="navbar">
      <a class="logo" href="/home">LabReserve.</a>
      <ul class="nav-links">
        {{#if (eq user.role "Lab Technician")}}
          <li><a href="/adminSearch">Search</a></li>
        {{/if}}
        <li><a href="/labs">Laboratories</a></li>
        <li><a href="/reservation">Reserve</a></li>
        <li><a href="/manage">Manage</a></li>
        <li><a href="/profile/{{../user._id}}">Profile</a></li>
        <li><a href="#" id="logoutBtn">Logout</a></li>
      </ul>
    </nav>
  </header>

  <main class="container">
    <h2>Slot Availability</h2>
    <p class="subtitle">Find laboratory seats that are open for reservation.</p>

    <div style="margin-bottom: 25px;">
      <select class="lab-select" id="labSelect">
        <option value="">Choose a lab...</option>
        {{#each labs}}
          <option value="{{this._id}}">{{this.lab}}</option>
        {{/each}}
      </select>
    </div>

    <div class="seat-map">
      <div class="screen">Blackboard / Whiteboard</div>

      <div class="seat-grid" id="seatGrid">
        <div style="padding: 60px; text-align: center; color: #666;">
          <p>Select a laboratory to view available seats</p>
        </div>
      </div>

      <div id="seatReservationPanel" class="seat-reservation-panel" style="display:none;">
        <h3 id="reservationPanelTitle">Select a seat to view slot availability</h3>
        <div class="reservation-controls">
          <label for="reservationDate">Choose Date</label>
          <input type="date" id="reservationDate" />
        </div>
        <div id="reservationTimeslots" class="reservation-timeslots">
          <p class="hint">Select a seat and date to see available time slots.</p>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/script.js"></script>

  <script>
    const labSelect = document.getElementById('labSelect');
    const seatGrid = document.getElementById('seatGrid');
    const reservationPanel = document.getElementById('seatReservationPanel');
    const reservationDate = document.getElementById('reservationDate');
    const timeslotsDiv = document.getElementById('reservationTimeslots');
    let selectedSeat = null;
    let selectedLabId = null;

    labSelect.addEventListener('change', async function () {
      const labId = this.value;
      selectedLabId = labId;
      selectedSeat = null;
      reservationPanel.style.display = 'none';

      if (!labId) {
        seatGrid.innerHTML = `
          <div style="padding: 60px; text-align: center; color: #666; display: flex; justify-content: center;">
            <p style="white-space: nowrap;">Select a laboratory to view available seats</p>
          </div>
        `;
        return;
      }

      seatGrid.innerHTML = '<div style="padding: 60px; text-align: center;">Loading seats...</div>';

      try {
        const response = await fetch(`/labs/${labId}`);
        const lab = await response.json();

        seatGrid.innerHTML = `
          <div style="display: grid; grid-template-columns: repeat(12, 88px); gap: 12px; justify-content: center; margin: 0 auto;">
            ${lab.seats.map(seat => `
              <div class="seat ${seat.status === 'Reserved' ? 'reserved' : ''}" 
                   style="cursor: pointer;" 
                   onclick="selectSeat('${seat.seatNumber}', '${lab._id}')">
                ${seat.seatNumber}
              </div>
            `).join('')}
          </div>
        `;
      } catch (err) {
        console.error('Error loading lab:', err);
        seatGrid.innerHTML = '<p style="color: red; padding: 60px; text-align: center;">Error loading seats. Try again.</p>';
      }
    });

    function selectSeat(seatNumber, labId) {
      selectedSeat = seatNumber;
      selectedLabId = labId;
      reservationPanel.style.display = 'block';
      reservationPanel.querySelector('#reservationPanelTitle').innerText = `Seat ${seatNumber}`;

      timeslotsDiv.innerHTML = '<p class="hint">Select a date to see available time slots.</p>';
    }

    reservationDate.addEventListener('change', async function () {
      if (!selectedSeat || !selectedLabId) return;
      const date = this.value;
    
      if (!date) return;
    
      timeslotsDiv.innerHTML = '<p>Loading available slots...</p>';
    
      try {
        const response = await fetch(`/labs/${selectedLabId}/slots?seat=${selectedSeat}&date=${date}`);
        const data = await response.json();
    
        console.log("Slots received:", data);
    
        const slots = data.availableSlots;
    
        if (!slots || slots.length === 0) {
          timeslotsDiv.innerHTML = '<p>No available time slots for this seat on this date.</p>';
          return;
        }
    
        timeslotsDiv.innerHTML = `
          <ul>
            ${slots.map(slot => `
              <li>
                ${slot}
                <button onclick="goToReservation('${selectedLabId}', '${selectedSeat}', '${date}', '${slot}')">
                  Reserve
                </button>
              </li>
            `).join('')}
          </ul>
        `;
      } catch (err) {
        console.error('Error fetching timeslots:', err);
        timeslotsDiv.innerHTML = '<p style="color:red;">Error fetching timeslots. Try again.</p>';
      }
    });

    function goToReservation(labId, seatNumber, date, time) {
      const url = new URL('/reservation', window.location.origin);
      url.searchParams.append('lab', labId);
      url.searchParams.append('seat', seatNumber);
      url.searchParams.append('date', date);
      url.searchParams.append('start_time', time);
      window.location.href = url;
    }
  </script>

  {{> logout}}
</body>
</html>
