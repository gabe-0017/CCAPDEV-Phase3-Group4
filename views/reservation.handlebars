<!doctype html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <title>Book Reservation</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>

  <body class="bg">

    <header>
      <nav class="navbar">

        <a class="logo" href="/home">LabReserve.</a>

        <ul class="nav-links">
          <li><a href="/labs">Laboratories</a></li>
          <li><a href="/reservation">Reserve</a></li>
          <li><a href="/manage">Manage</a></li>
          <li><a href="/profile">Profile</a></li>
          <li><a href="#" id="logoutBtn">Logout</a></li>
        </ul>

      </nav>
    </header>

    <main class="container">

      <h2>Reservation Form</h2>
      <p class="subtitle">Fill up the form to make a seat reservation.</p>

      <div class="form-card">

        <form action="/reserve" method="POST">

          <input type="hidden" name="userId" value="{{user._id}}">

          <div class="form-group">

            <label>Laboratory</label>

            <select name="lab" required>

              <option disabled selected>Select a lab</option>

              {{#each labs}}
                <option value="{{this._id}}">
                  {{this.lab}}
                </option>
              {{/each}}

            </select>

          </div>

          <div class="form-group">

            <label>Seat</label>

            <select name="seat" required>

              <option disabled selected>Select a seat</option>

              {{#each labs.[0].seats}}
                <option value="{{this.seatNumber}}">
                  {{this.seatNumber}}
                </option>
              {{/each}}

            </select>

          </div>

          <div class="form-row">

            <div class="form-group">
              <label>Date</label>
              <input type="date" name="date" required />
            </div>

            <div class="form-group">
              <label>Time</label>
              <input type="time" name="time" required />
            </div>

          </div>

          <div class="form-group">

            <label>Purpose</label>
            <input type="text" name="purpose" required />

          </div>

          <button class="btn-large">
            Confirm Reservation
          </button>

        </form>

      </div>

    </main>

    <script src="/js/script.js"></script>

  </body>

</html>