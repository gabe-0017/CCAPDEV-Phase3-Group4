<!doctype html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <title>Book Reservation</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>

  <body class="bg">

    <header>
      <nav class="navbar">

        <a class="logo" href="/home">LabReserve.</a>

        <ul class="nav-links">
          <li><a href="/labs">Laboratories</a></li>
          <li><a href="/reservation">Reserve</a></li>
          <li><a href="/manage">Manage</a></li>
          <li><a href="/profile">Profile</a></li>
          <li><a href="#" id="logoutBtn">Logout</a></li>
        </ul>

      </nav>
    </header>

    <main class="container">

      <h2>Reservation Form</h2>
      <p class="subtitle">Fill up the form to make a seat reservation.</p>

      <div class="form-card">

        <form action="/reserve" method="POST">

          <input type="hidden" name="userId" value="{{user._id}}">

          <div class="form-group">
            <label>Laboratory</label>
            <select name="lab" id="labSelect" required>
              <option disabled selected>Select a lab</option>
              {{#each labs}}
                <option value="{{this._id}}">{{this.lab}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label>Seat</label>
            <select name="seat" id="seatSelect" required>
              <option disabled selected>Select a seat</option>
            </select>
          </div>

          <div class="form-row">

            <div class="form-group">
              <label>Date</label>
              <input type="date" name="date" required />
            </div>

            <div class="form-group">
              <label>Start Time</label>
              <input type="time" name="start_time" required step="1800" />
            </div>

            <div class="form-group">
              <label>End Time</label>
              <input type="time" name="end_time" required step="1800" />
            </div>

          </div>

          <div class="form-group">

            <label>Purpose</label>
            <input type="text" name="purpose" required />

          </div>

          <button class="btn-large">
            Confirm Reservation
          </button>

        </form>

      </div>

    </main>

    <script src="/js/script.js"></script>

    <script>
      const labSelect = document.getElementById('labSelect');
      const seatSelect = document.getElementById('seatSelect');

      labSelect.addEventListener('change', async () => {
        const labId = labSelect.value;

        seatSelect.innerHTML = '<option disabled selected>Select a seat</option>';

        if (!labId) return;

        try {
          const res = await fetch(`/labs/${labId}`);
          const lab = await res.json();

          lab.seats.forEach(seat => {
            const option = document.createElement('option');
            option.value = seat.seatNumber;
            option.textContent = seat.seatNumber;
            seatSelect.appendChild(option);
          });

        } catch (err) {
          console.error('Error loading seats:', err);
          seatSelect.innerHTML = '<option disabled>Error loading seats</option>';
        }
      });
    </script>

  </body>

</html>

